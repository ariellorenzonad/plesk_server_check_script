def sum_disk_space(disk_space_list):
    total_disk_space = 0
    for disk_space in disk_space_list:
        disk_space_value, disk_space_unit = disk_space.split()
        if disk_space_unit == "B": total_disk_space += float(disk_space_value) / 1024 / 1024 / 1024
        elif disk_space_unit == "KB": total_disk_space += float(disk_space_value) / 1024 / 1024
        elif disk_space_unit == "MB": total_disk_space += float(disk_space_value) / 1024
        elif disk_space_unit == "GB": total_disk_space += float(disk_space_value)
        elif disk_space_unit == "TB": total_disk_space += float(disk_space_value) * 1024
        elif disk_space_unit == "unlimited": return "unlimited"
        else: return "ERROR: UNRECOGNIZED UNIT"
    return f"{round(total_disk_space, 2)} GB"

def convert_bytes(value, unit):
    # PURPOSE: Converts the value of disk space or traffic to bytes for easier comparison. It takes in the value and unit as parameters and returns the value in bytes. If the unit is "unlimited", it returns infinity. If an unrecognized unit is encountered, it returns an error message.
    if unit in ["B", "B/month"]: return float(value)
    elif unit in ["KB", "KB/month"]: return float(value) * 1024
    elif unit in ["MB", "MB/month"]: return float(value) * pow(1024,2)
    elif unit in ["GB", "GB/month"]: return float(value) * pow(1024,3)
    elif unit in ["TB", "TB/month"]: return float(value) * pow(1024,4)
    elif unit == "unlimited": return float('inf')
    else: return -1

def compare_disk_space(sp_disk_space, actual_disk_space):
    if len(sp_disk_space) == 0 or len(actual_disk_space) == 0: return "ERROR: COULD NOT GET DISK SPACE INFORMATION"
    sp_disk_space_value, sp_disk_space_unit = sp_disk_space.split()
    actual_disk_space_value, actual_disk_space_unit = actual_disk_space.split()
    sp_disk_space_value = convert_bytes(sp_disk_space_value, sp_disk_space_unit)
    actual_disk_space_value = convert_bytes(actual_disk_space_value, actual_disk_space_unit)
    if sp_disk_space_value == -1 or actual_disk_space_value == -1: return "ERROR: UNRECOGNIZED UNIT"
    elif sp_disk_space_value == float('inf'): return "HEALTHY"
    elif actual_disk_space_value == float('inf'): return "NOT HEALTHY"
    elif actual_disk_space_value <= sp_disk_space_value: return "HEALTHY"
    else: return "NOT HEALTHY"

def compare_traffic(sp_traffic, actual_traffic):
    if len(sp_traffic) == 0 or len(actual_traffic) == 0: return "ERROR: COULD NOT GET TRAFFIC INFORMATION"
    sp_traffic_value, sp_traffic_unit = sp_traffic.split()
    actual_traffic_value, actual_traffic_unit = actual_traffic.split()
    actual_traffic_unit = actual_traffic_unit.replace('Month','month')
    sp_traffice_value = convert_bytes(sp_traffic_value, sp_traffic_unit)
    actual_traffic_value = convert_bytes(actual_traffic_value, actual_traffic_unit)
    if sp_traffice_value == -1 or actual_traffic_value == -1: return "ERROR: UNRECOGNIZED UNIT"
    elif sp_traffice_value == float('inf'): return "HEALTHY"
    elif actual_traffic_value == float('inf'): return "NOT HEALTHY"
    elif actual_traffic_value <= sp_traffice_value: return "HEALTHY"
    else: return "NOT HEALTHY"

