def mem_monitor(interval=1, amount=10):
    print(f"Getting RAM information...")
    mem_readings = []
    for i in range(0, amount):
        mem = psutil.virtual_memory()
        mem_reading = {
            "percentage": mem.percent,
            "used": mem.used,
            "total": mem.total
        }
        mem_readings.append(mem_reading)
        time.sleep(interval)

    return mem_readings

