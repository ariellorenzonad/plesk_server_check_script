from typing import Any,List

def longest_per_column(data: List[List[Any]]) -> List[int]:
    """
    Returns a list where each index contains the length
    of the longest string in that column.

    Runs in O(n) time where n = total number of elements.
    """
    if not data:
        return []

    # Determine max number of columns
    col_count = max(len(row) for row in data)

    # Initialize max lengths
    max_lengths = [0] * col_count

    # Single pass through all cells
    for row in data:
        for col_index, value in enumerate(row):
            length = len(str(value))
            if length > max_lengths[col_index]:
                max_lengths[col_index] = length

    return max_lengths

